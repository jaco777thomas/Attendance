@model List<Attendance.Models.ViewModels.RoleIndexViewModel>
@{
    ViewData["Title"] = "Role Management";
}

<div class="page-header">
    <div>
        <h1>🔐 Role Management</h1>
        <p>Define roles and assign granular permissions.</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">➕ Create New Role</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Role Name</th>
                    <th>Description</th>
                    <th>Permissions</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model)
                {
                    <tr>
                        <td><strong>@role.Name</strong></td>
                        <td>@role.Description</td>
                        <td><span class="badge badge-info">@role.PermissionCount permissions</span></td>
                        <td>
                            <div class="btn-group">
                                <a href="@Url.Action("Edit", new { id = role.Id })" class="btn btn-secondary btn-sm">✏️ Edit</a>
                                @if (role.Name != "HeadMaster" && role.Name != "Admin" && role.Name != "Teacher")
                                {
                                    <form asp-action="Delete" asp-route-id="@role.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this role?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">🗑️ Delete</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
