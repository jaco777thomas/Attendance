@model Attendance.Models.ViewModels.UserCreateViewModel
@{ ViewData["Title"] = "Add User"; }
<div class="page-header"><h1>➕ Add User</h1><a href="@Url.Action("Index")" class="btn btn-secondary">← Back</a></div>
<div class="card" style="max-width:520px;"><div class="card-body">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger"></div>
        <div class="form-group"><label>Full Name *</label><input asp-for="Name" class="form-control" id="userName"/><span asp-validation-for="Name" class="text-danger"></span></div>
        <div class="form-group"><label>Email *</label><input asp-for="Email" class="form-control" type="email" id="userEmail"/><span asp-validation-for="Email" class="text-danger"></span></div>
        <div class="form-group"><label>Phone</label><input asp-for="Phone" class="form-control" type="tel" id="userPhone"/></div>
        <div class="form-group">
            <label>Roles *</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; background: var(--bg-alt); padding: 0.75rem; border-radius: 8px;">
                @if (Model.AvailableRoles != null)
                {
                    foreach (var role in Model.AvailableRoles)
                    {
                        <div class="checkbox-item" style="display: flex; align-items: center; gap: 0.5rem;">
                            <input type="checkbox" name="SelectedRoleIds" value="@role.Id" id="role_@role.Id" 
                                   class="role-checkbox" data-name="@role.Name"
                                   @(Model.SelectedRoleIds.Contains(role.Id) ? "checked" : "") />
                            <label for="role_@role.Id" style="margin: 0; cursor: pointer;">@role.Name</label>
                        </div>
                    }
                }
            </div>
            <span asp-validation-for="SelectedRoleIds" class="text-danger"></span>
        </div>
        
        <div id="teacherAllocation" style="display:none; border:1px solid var(--border); padding:1rem; margin-bottom:1rem; border-radius:8px;">
            <p><strong>Teacher Allocation</strong></p>
            <div class="form-group">
                <label>Assigned Class</label>
                <select asp-for="AssignedClass" class="form-select" id="assignedClass">
                    <option value="">None</option>
                    <option value="NURSERY" selected="@(Model.AssignedClass == "NURSERY")">NURSERY</option>
                    <option value="LKG">LKG</option>
                    <option value="UKG">UKG</option>
                    @for (int i = 1; i <= 15; i++) { <option value="@i">Class @i</option> }
                </select>
            </div>
            <div class="form-group">
                <label>Assigned Division</label>
                <select asp-for="AssignedDivision" asp-items="Html.GetEnumSelectList<Attendance.Models.Entities.Division>()" class="form-select">
                    <option value="">None</option>
                </select>
            </div>
            <div class="form-group">
                <label>Assigned Language</label>
                <select asp-for="AssignedLanguage" asp-items="Html.GetEnumSelectList<Attendance.Models.Entities.Language>()" class="form-select">
                    <option value="">None</option>
                </select>
            </div>
        </div>
        <div class="form-group"><label>Password *</label><input asp-for="Password" class="form-control" type="password" id="userPwd"/><span asp-validation-for="Password" class="text-danger"></span></div>
        <div class="form-group"><label>Confirm Password *</label><input asp-for="ConfirmPassword" class="form-control" type="password" id="userPwdConfirm"/></div>
        <div style="display:flex; gap:1rem; margin-top:2rem;">
            <button type="submit" class="btn btn-primary" id="saveUser" style="flex:1">💾 Create User</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary" style="flex:1">Cancel</a>
        </div>
    </form>
</div></div>

@section Scripts {
<script>
    const checkboxes = document.querySelectorAll('.role-checkbox');
    const allocationDiv = document.getElementById('teacherAllocation');
    
    function toggleAllocation() {
        let isTeacher = false;
        checkboxes.forEach(cb => {
            if (cb.checked && cb.getAttribute('data-name') === 'Teacher') isTeacher = true;
        });
        allocationDiv.style.display = isTeacher ? 'block' : 'none';
    }
    
    checkboxes.forEach(cb => cb.addEventListener('change', toggleAllocation));
    toggleAllocation();
</script>
}
