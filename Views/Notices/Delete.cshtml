@model Attendance.Models.Entities.Notice
@{ ViewData["Title"] = "Delete Notice"; }
<div class="page-header"><h1>🗑️ Delete Notice</h1></div>
<div class="card" style="max-width:480px;"><div class="card-body">
    <div class="alert alert-danger">Delete notice: <strong>@Model.Title</strong>?</div>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="btn-group">
            <button type="submit" class="btn btn-danger" id="confirmDeleteNotice">🗑️ Delete</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div></div>
