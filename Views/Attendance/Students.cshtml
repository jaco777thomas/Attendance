@model Attendance.Models.ViewModels.AttendanceMarkViewModel
@{
    ViewData["Title"] = "Student Attendance";
}

<div class="page-header"><div><h1>✅ Student Attendance</h1><p>Select class and date to mark attendance</p></div></div>

<!-- Selection Card -->
<div class="card" style="margin-bottom:1.25rem;">
    <div class="card-body">
        <div class="form-row" id="selectionRow">
            <div class="form-group">
                <label>Date *</label>
                <input type="date" id="attDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")"/>
            </div>
            <div class="form-group">
                <label>Class *</label>
                <select id="attClass" class="form-select" disabled="@(User.IsInRole("Teacher") && !string.IsNullOrEmpty(Model.Class) ? "disabled" : null)">
                    <option value="">-- Select Class --</option>
                     <option value="NURSERY" selected="@(Model.Class == "NURSERY")">NURSERY</option>
                    <option value="LKG" selected="@(Model.Class == "LKG")">LKG</option>
                    <option value="UKG" selected="@(Model.Class == "UKG")">UKG</option>
                    @for (int i = 1; i <= 15; i++) { 
                        <option value="@i" selected="@(Model.Class == i.ToString())">Class @i</option> 
                    }
                </select>
                @if (User.IsInRole("Teacher") && !string.IsNullOrEmpty(Model.Class)) { <input type="hidden" id="hiddenClass" value="@Model.Class" /> }
            </div>
            <div class="form-group">
                <label>Division *</label>
                <select id="attDivision" class="form-select" disabled="@(User.IsInRole("Teacher") && !string.IsNullOrEmpty(Model.Class) ? "disabled" : null)">
                    <option value="">-- Select Division --</option>
                    <option value="A" selected="@(Model.Division == Attendance.Models.Entities.Division.A)">Division A</option>
                    <option value="B" selected="@(Model.Division == Attendance.Models.Entities.Division.B)">Division B</option>
                    <option value="C" selected="@(Model.Division == Attendance.Models.Entities.Division.C)">Division C</option>
                </select>
                @if (User.IsInRole("Teacher") && !string.IsNullOrEmpty(Model.Class)) { <input type="hidden" id="hiddenDivision" value="@Model.Division" /> }
            </div>
            <div class="form-group">
                <label>Language *</label>
                <select id="attLanguage" class="form-select" disabled="@(User.IsInRole("Teacher") && !string.IsNullOrEmpty(Model.Class) ? "disabled" : null)">
                    <option value="">-- Select Language --</option>
                    <option value="English" selected="@(Model.Language == Attendance.Models.Entities.Language.English)">English</option>
                    <option value="Kannada" selected="@(Model.Language == Attendance.Models.Entities.Language.Kannada)">Kannada</option>
                    <option value="Malayalam" selected="@(Model.Language == Attendance.Models.Entities.Language.Malayalam)">Malayalam</option>
                </select>
                @if (User.IsInRole("Teacher") && !string.IsNullOrEmpty(Model.Class)) { <input type="hidden" id="hiddenLanguage" value="@Model.Language" /> }
            </div>
            <div class="form-group">
                <label>&nbsp;</label>
                <button class="btn btn-primary" id="loadStudentsBtn" onclick="loadStudents()">📋 Load Students</button>
            </div>
        </div>
    </div>
</div>

<!-- Attendance Table -->
<div id="attendanceSection" style="display:none;">
    <div class="card">
        <div class="card-header">
            <h5 id="attTableTitle">Attendance List</h5>
            <div class="btn-group">
                <button class="btn btn-success btn-sm" id="markAllPresent" onclick="markAll('Present')">✅ All Present</button>
                <button class="btn btn-danger btn-sm" id="markAllAbsent" onclick="markAll('Absent')">❌ All Absent</button>
            </div>
        </div>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr><th>#</th><th>Student Name</th><th style="text-align:center;">Attendance</th></tr>
                </thead>
                <tbody id="attendanceBody"></tbody>
            </table>
        </div>
        <div class="card-body" style="border-top:1px solid var(--border);">
            <button class="btn btn-primary" id="saveAttendanceBtn" onclick="saveAttendance()">💾 Save Attendance</button>
            <span id="saveMsg" style="margin-left:1rem;font-size:.875rem;color:var(--success);display:none;">✅ Saved successfully!</span>
        </div>
    </div>
</div>

<div id="noStudentsMsg" style="display:none;" class="alert alert-info">
    🔍 <strong>No active students found.</strong> 
    <br/>Please verify your assigned Class, Division, and Language. If you just added students, ensure their status is set to "Active".
</div>

@section Scripts {
<script>
let currentRows = [];

async function loadStudents() {
    const dateInput = document.getElementById('attDate');
    const classSelect = document.getElementById('attClass');
    const divSelect = document.getElementById('attDivision');
    const langSelect = document.getElementById('attLanguage');
    const hiddenClass = document.getElementById('hiddenClass');
    const hiddenDivision = document.getElementById('hiddenDivision');
    const hiddenLanguage = document.getElementById('hiddenLanguage');

    const date = dateInput.value;
    const cls = classSelect.disabled && hiddenClass ? hiddenClass.value : classSelect.value;
    const div = divSelect.disabled && hiddenDivision ? hiddenDivision.value : divSelect.value;
    const lang = langSelect.disabled && hiddenLanguage ? hiddenLanguage.value : langSelect.value;
    
    if (!date || !cls || !div || !lang) { alert('Please select date, class, division, and language.'); return; }

    const btn = document.getElementById('loadStudentsBtn');
    btn.textContent = '⏳ Loading...'; btn.disabled = true;

    try {
        const res = await fetch(`/Attendance/LoadStudents?classNo=${cls}&division=${div}&language=${lang}&date=${date}`);
        if (!res.ok) {
            const err = await res.json();
            alert(err.message || 'Error loading students');
            btn.textContent = '📋 Load Students'; btn.disabled = false;
            return;
        }
        currentRows = await res.json();
        
        document.getElementById('attTableTitle').textContent = `Class ${cls}${div} – ${new Date(date).toLocaleDateString('en-IN', {dateStyle:'medium'})}`;

        if (!currentRows.length) {
            document.getElementById('attendanceSection').style.display = 'none';
            document.getElementById('noStudentsMsg').style.display = 'block';
        } else {
            document.getElementById('noStudentsMsg').style.display = 'none';
            document.getElementById('attendanceSection').style.display = 'block';
            renderTable();
        }
    } catch (e) {
        console.error(e);
        alert('Network error or server unavailable');
    } finally {
        btn.textContent = '📋 Load Students'; btn.disabled = false;
    }
}

function renderTable() {
    const tbody = document.getElementById('attendanceBody');
    tbody.innerHTML = currentRows.map((r, i) => `
        <tr>
            <td>${i+1}</td>
            <td><strong>${r.studentName}</strong></td>
            <td>
                <div class="att-status">
                    <label class="att-radio-label present">
                        <input type="radio" name="att_${r.studentId}" value="Present" ${r.status === 'Present' ? 'checked' : ''} onchange="rowChanged(${i})">
                        ✅ Present
                    </label>
                    <label class="att-radio-label absent">
                        <input type="radio" name="att_${r.studentId}" value="Absent" ${r.status === 'Absent' ? 'checked' : ''} onchange="rowChanged(${i})">
                        ❌ Absent
                    </label>
                </div>
            </td>
        </tr>`).join('');
}

function rowChanged(i) {
    const val = document.querySelector(`input[name="att_${currentRows[i].studentId}"]:checked`)?.value;
    if (val) currentRows[i].status = val;
}

function markAll(status) {
    currentRows.forEach((r, i) => {
        r.status = status;
        const radio = document.querySelector(`input[name="att_${r.studentId}"][value="${status}"]`);
        if (radio) radio.checked = true;
    });
}

async function saveAttendance() {
    const date = document.getElementById('attDate').value;
    const btn = document.getElementById('saveAttendanceBtn');
    btn.textContent = '⏳ Saving...'; btn.disabled = true;

    try {
        const res = await fetch('/Attendance/SaveStudentAttendance', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify({ date, rows: currentRows })
        });
        
        if (!res.ok) {
            const txt = await res.text();
            console.error(txt);
            alert('Failed to save: ' + (txt.substring(0, 100) || 'Server error'));
            return;
        }

        const data = await res.json();
        if (data.success) {
            const msg = document.getElementById('saveMsg');
            msg.style.display = 'inline'; setTimeout(() => msg.style.display = 'none', 3000);
        } else {
            alert(data.message || 'Error occurred while saving');
        }
    } catch (e) {
        console.error(e);
        alert('Network error or server unavailable');
    } finally {
        btn.textContent = '💾 Save Attendance'; btn.disabled = false;
    }
}

function getToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}
</script>
<form id="__af"> @Html.AntiForgeryToken() </form>
<script>
// re-export the token from the hidden form
window.__afToken = document.querySelector('#__af input[name="__RequestVerificationToken"]')?.value ?? '';
function getToken() { return window.__afToken; }
</script>
}
