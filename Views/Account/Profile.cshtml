@model Attendance.Models.ViewModels.UserProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}
<div class="page-header"><div><h1>👤 My Profile</h1><p>Update your account information</p></div></div>
<div class="card" style="max-width:520px;">
    <div class="card-body">
        <form asp-action="Profile" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id"/>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="form-group"><label>Full Name</label><input asp-for="Name" class="form-control" id="profileName"/><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="form-group"><label>Email</label><input asp-for="Email" class="form-control" type="email" id="profileEmail"/><span asp-validation-for="Email" class="text-danger"></span></div>
            <div class="form-group"><label>Phone</label><input asp-for="Phone" class="form-control" type="tel" id="profilePhone"/></div>
            <hr style="margin:1rem 0;border-color:var(--border)"/>
            <p style="font-size:.8rem;color:var(--text-muted);margin-bottom:.75rem;">Leave password blank to keep existing password</p>
            <div class="form-group"><label>New Password</label><input asp-for="NewPassword" class="form-control" type="password" id="profilePwd"/><span asp-validation-for="NewPassword" class="text-danger"></span></div>
            <div class="form-group"><label>Confirm Password</label><input asp-for="ConfirmPassword" class="form-control" type="password" id="profilePwdConfirm"/></div>
            <button type="submit" class="btn btn-primary" id="saveProfileBtn">💾 Save Changes</button>
        </form>
    </div>
</div>
